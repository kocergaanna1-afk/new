# Telegram
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789,987654321

# OpenAI Whisper (нужен только если TRANSCRIPTION_PROVIDER=openai)
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=ru

# Пути
KNOWLEDGE_BASE_PATH=./knowledge_base

# Опции
MAX_VOICE_DURATION=300

# === Выбор провайдера транскрипции ===
# openai  — платный, облачный, лучшее качество
# local   — бесплатный, faster-whisper на сервере (нужно ~2 ГБ RAM)
# vosk    — бесплатный, лёгкий, офлайн (~50 МБ RAM для small модели)
TRANSCRIPTION_PROVIDER=local

# faster-whisper (если TRANSCRIPTION_PROVIDER=local)
# Модели: tiny, base, small, medium, large-v3
# tiny — быстро, слабое качество | medium — баланс | large-v3 — лучшее
LOCAL_WHISPER_MODEL=medium
LOCAL_WHISPER_COMPUTE=int8

# Vosk (если TRANSCRIPTION_PROVIDER=vosk)
# Скачайте модель: https://alphacephei.com/vosk/models
# Русский: vosk-model-small-ru-0.22 (45 МБ) или vosk-model-ru-0.42 (1.8 ГБ)
VOSK_MODEL_PATH=./vosk-model
